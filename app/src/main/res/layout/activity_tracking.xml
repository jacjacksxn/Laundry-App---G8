<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/service_icon_bg"
        android:contentDescription="@string/cancel"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_dark" />

    <TextView
        android:id="@+id/track_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/status"
        android:textColor="@color/text_dark"
        android:textSize="32sp"
        android:fontFamily="@font/lobster_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:paddingHorizontal="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/track_title">

        <!-- Step 1 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <View
                android:id="@+id/dot1"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/status_dot"
                android:backgroundTint="@color/primary_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/dot1"
                android:layout_marginStart="24dp"
                android:text="@string/order_received"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/sofia" />
        </RelativeLayout>

        <View
            android:layout_width="2dp"
            android:layout_height="48dp"
            android:layout_marginStart="7dp"
            android:background="@color/primary_green" />

        <!-- Step 2 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <View
                android:id="@+id/dot2"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/status_dot"
                android:backgroundTint="@color/primary_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/dot2"
                android:layout_marginStart="24dp"
                android:text="@string/washing"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/sofia" />
        </RelativeLayout>

        <View
            android:layout_width="2dp"
            android:layout_height="48dp"
            android:layout_marginStart="7dp"
            android:background="#10000000" />

        <!-- Step 3 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <View
                android:id="@+id/dot3"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/status_dot"
                android:backgroundTint="#20000000" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/dot3"
                android:layout_marginStart="24dp"
                android:text="@string/delivering"
                android:textColor="@color/text_grey"
                android:fontFamily="@font/sofia" />
        </RelativeLayout>

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F2F4F7"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/primary_button_bg"
                android:padding="12dp"
                android:src="@drawable/ic_call"
                app:backgroundTint="@null"
                app:tint="@color/white"
                android:contentDescription="@string/support" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support"
                    android:textColor="@color/text_dark"
                    android:fontFamily="@font/lobster_2"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/talk_to_us"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey"
                    android:fontFamily="@font/sofia" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>