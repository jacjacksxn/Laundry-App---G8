<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FC"
    tools:context=".OrderStatusFragment">

    <!-- Top Action Bar / Back Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="Go Back"
            android:src="@drawable/ic_back"
            app:tint="#1E293B" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Page Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Status"
        android:textColor="#1E293B"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Timeline Container Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTimeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Vertical Timeline Track Indicators -->
            <!-- Line 1 (Active line between Step 1 & 2) -->
            <View
                android:id="@+id/line1"
                android:layout_width="4dp"
                android:layout_height="60dp"
                android:layout_below="@id/step1_circle"
                android:layout_alignStart="@id/step1_circle"
                android:layout_alignEnd="@id/step1_circle"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#10B981" />

            <!-- Line 2 (Inactive line between Step 2 & 3) -->
            <View
                android:id="@+id/line2"
                android:layout_width="4dp"
                android:layout_height="60dp"
                android:layout_below="@id/step2_circle"
                android:layout_alignStart="@id/step2_circle"
                android:layout_alignEnd="@id/step2_circle"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="#E2E8F0" />

            <!-- STEP 1: Order Received (Completed) -->
            <FrameLayout
                android:id="@+id/step1_circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/shape_circle_active">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/baseline_check_24"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/step1_circle"
                android:layout_alignTop="@id/step1_circle"
                android:layout_alignBottom="@id/step1_circle"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:text="Order Received"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- STEP 2: Washing (Active/In Progress) -->
            <FrameLayout
                android:id="@+id/step2_circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_below="@id/step1_circle"
                android:layout_marginTop="60dp"
                android:background="@drawable/shape_circle_active">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/baseline_local_laundry_service_24"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/step2_circle"
                android:layout_alignTop="@id/step2_circle"
                android:layout_alignBottom="@id/step2_circle"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:text="Washing"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- STEP 3: Delivering (Pending) -->
            <FrameLayout
                android:id="@+id/step3_circle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_below="@id/step2_circle"
                android:layout_marginTop="60dp"
                android:background="@drawable/shape_circle_inactive">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/baseline_local_shipping_24"
                    app:tint="#94A3B8" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/step3_circle"
                android:layout_alignTop="@id/step3_circle"
                android:layout_alignBottom="@id/step3_circle"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:text="Delivering"
                android:textColor="#94A3B8"
                android:textSize="16sp" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Support Section Footer Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSupport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Deep Royal Blue Call Icon Background -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardBackgroundColor="#1E3A8A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_call"
                    app:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Support"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Talk to us about your order"
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>